# ============================================================
# ChinaVista 环境变量模板 (.env.example)
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ⚠️ .env 已加入 .gitignore，不会被提交
# ============================================================

# ------------------------ 应用基础 ------------------------
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# ------------------------ 数据库 ------------------------
# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=chinavista
DB_PASSWORD=<your-db-password>
DB_NAME=chinavista

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<your-redis-password>

# Elasticsearch
ES_HOST=http://localhost:9200
ES_USER=elastic
ES_PASSWORD=<your-es-password>

# ------------------------ JWT / Auth ------------------------
JWT_SECRET=<generate-a-random-64-char-string>
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=<generate-another-random-64-char-string>
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------ AI / LLM ------------------------
# OpenAI
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_MODEL=deepseek-chat

# Qwen (阿里通义千问)
QWEN_API_KEY=<your-qwen-api-key>
QWEN_MODEL=qwen-max

# ------------------------ 阿里云 ------------------------
ALIBABA_ACCESS_KEY_ID=<your-aliyun-access-key-id>
ALIBABA_ACCESS_KEY_SECRET=<your-aliyun-access-key-secret>
OSS_BUCKET=<your-oss-bucket-name>
OSS_REGION=oss-cn-hangzhou
OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
CDN_DOMAIN=https://cdn.chinavista.cn

# ------------------------ 地图服务 ------------------------
# 高德地图 (AMap)
AMAP_API_KEY=<your-amap-api-key>
AMAP_API_SECRET=<your-amap-api-secret>

# 百度地图
BAIDU_MAP_AK=<your-baidu-map-ak>

# ------------------------ 支付 ------------------------
# 微信支付
WECHAT_PAY_APP_ID=<your-app-id>
WECHAT_PAY_MCH_ID=<your-mch-id>
WECHAT_PAY_API_KEY=<your-api-key>
WECHAT_PAY_API_V3_KEY=<your-api-v3-key>
WECHAT_PAY_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
WECHAT_PAY_CERT_SERIAL_NO=<your-cert-serial>

# 支付宝
ALIPAY_APP_ID=<your-app-id>
ALIPAY_PRIVATE_KEY=<your-private-key>
ALIPAY_PUBLIC_KEY=<your-alipay-public-key>
ALIPAY_NOTIFY_URL=https://api.chinavista.cn/payments/alipay/callback

# 银联
UNIONPAY_MERCHANT_ID=<your-merchant-id>
UNIONPAY_SECRET=<your-unionpay-secret>

# Apple Pay
APPLE_PAY_MERCHANT_ID=<your-merchant-id>
APPLE_PAY_CERT_PATH=/path/to/cert.pem

# ------------------------ 第三方服务 ------------------------
# 12306 接口
RAILWAY_API_KEY=<your-12306-api-key>
RAILWAY_API_SECRET=<your-12306-api-secret>

# 神州租车
SHENZHOU_API_KEY=<your-shenzhou-api-key>

# 一嗨租车
EHAI_API_KEY=<your-ehai-api-key>

# 天气 API
WEATHER_API_KEY=<your-weather-api-key>

# 短信服务 (阿里云)
SMS_ACCESS_KEY_ID=<your-sms-key-id>
SMS_ACCESS_KEY_SECRET=<your-sms-key-secret>
SMS_SIGN_NAME=华景中国
SMS_TEMPLATE_CODE=<your-template-code>

# ------------------------ 国际化 ------------------------
NEXT_PUBLIC_DEFAULT_LOCALE=zh
NEXT_PUBLIC_SUPPORTED_LOCALES=zh,en,ja,ko,fr

# ------------------------ 安全 ------------------------
CSRF_SECRET=<generate-random-string>
CSP_REPORT_URI=https://chinavista.report-uri.com/r/d/csp/enforce
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
