#!/usr/bin/env bash
# ============================================================
# ChinaVista Pre-Commit Hook
# Scans staged changes for secrets, credentials, and keys
# Uses: gitleaks (primary) + fallback pattern scan
# ============================================================
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo -e "${YELLOW}🔍 ChinaVista Secret Scan: checking staged changes...${NC}"

# ---------- Layer 1: Gitleaks (comprehensive) ----------
if command -v gitleaks &>/dev/null; then
  GITLEAKS_OUTPUT=$(gitleaks protect --staged --config=".gitleaks.toml" --verbose 2>&1) || {
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}⛔ SECRETS DETECTED — COMMIT BLOCKED${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "$GITLEAKS_OUTPUT" | grep -E "(Finding|Secret|RuleID|File|Line|Commit)" || echo "$GITLEAKS_OUTPUT"
    echo ""
    echo -e "${YELLOW}解决方案 / How to fix:${NC}"
    echo "  1. 从代码中删除真实的密钥和凭证"
    echo "  2. 用环境变量替代: process.env.MY_SECRET"
    echo "  3. 如果是示例值，添加到 .gitleaks.toml 的 allowlist 中"
    echo "  4. 如果文件本来就不该提交，添加到 .gitignore"
    echo ""
    echo -e "${YELLOW}如果确认这是误报 (false positive):${NC}"
    echo "  git commit --no-verify  跳过检查（不推荐！请先确认）"
    echo ""
    exit 1
  }
  echo -e "${GREEN}✅ Gitleaks: no secrets detected${NC}"
else
  echo -e "${YELLOW}⚠️  Gitleaks not installed, falling back to basic scan${NC}"

  # ---------- Layer 2: Basic pattern scan (fallback) ----------
  STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
  VIOLATIONS=0

  for FILE in $STAGED_FILES; do
    # Skip binary and generated files
    case "$FILE" in
      *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff|*.woff2|*.ttf|*.eot|*.lock|*.sum) continue ;;
      package-lock.json|yarn.lock|pnpm-lock.yaml) continue ;;
    esac

    if [ ! -f "$FILE" ]; then continue; fi

    # Check for common secret patterns in staged version
    STAGED_CONTENT=$(git show ":$FILE" 2>/dev/null || true)

    # Pattern: Alibaba AccessKey
    if echo "$STAGED_CONTENT" | grep -qE 'LTAI[a-zA-Z0-9]{16,24}'; then
      echo -e "${RED}⛔ [$FILE] Alibaba Cloud AccessKey detected${NC}"
      VIOLATIONS=$((VIOLATIONS + 1))
    fi

    # Pattern: Generic API keys in assignment
    if echo "$STAGED_CONTENT" | grep -qiE '(api_key|api_secret|app_secret|secret_key|private_key|access_key)\s*[:=]\s*['\''"][A-Za-z0-9_\-]{20,}'\''"'; then
      echo -e "${RED}⛔ [$FILE] Possible API key/secret assignment detected${NC}"
      VIOLATIONS=$((VIOLATIONS + 1))
    fi

    # Pattern: Connection strings with passwords
    if echo "$STAGED_CONTENT" | grep -qE '(mysql|postgres|redis|mongodb)://[^:]+:[^@]+@'; then
      echo -e "${RED}⛔ [$FILE] Database connection string with embedded password detected${NC}"
      VIOLATIONS=$((VIOLATIONS + 1))
    fi

    # Pattern: JWT token-like strings (long base64)
    if echo "$STAGED_CONTENT" | grep -qE 'eyJ[A-Za-z0-9_\-]{50,}\.[A-Za-z0-9_\-]{20,}\.[A-Za-z0-9_\-]{10,}'; then
      echo -e "${YELLOW}⚠️  [$FILE] Possible hardcoded JWT token detected${NC}"
      VIOLATIONS=$((VIOLATIONS + 1))
    fi
  done

  if [ "$VIOLATIONS" -gt 0 ]; then
    echo ""
    echo -e "${RED}⛔ COMMIT BLOCKED: $VIOLATIONS potential secret(s) found${NC}"
    echo -e "${YELLOW}Install gitleaks for comprehensive scanning: brew install gitleaks${NC}"
    exit 1
  fi

  echo -e "${GREEN}✅ Basic scan: no obvious secrets detected${NC}"
fi

echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}✅ Secret scan passed — proceeding with commit${NC}"
echo -e "${GREEN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
